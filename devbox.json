{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.1/.schema/devbox.schema.json",
  "packages": ["python@3.12"],
  "shell": {
    "init_hook": [". $VENV_DIR/bin/activate"],
    "scripts": {
      "install": "pip install -e .[dev,svg]",
      "init": "cf-report init",
      "validate": "cf-report validate",
      "sync": "cf-report sync --last 7",
      "report": "cf-report report --last 7 -o ./cf-report-test.pdf",
      "lint": "ruff check --fix . && ruff format . && mypy src/ && pytest --tb=short"
    }
  }
}
